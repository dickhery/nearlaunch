# Relayer mode. Keep true for local development; set false for real 1Click swaps.
RELAYER_MOCK=true
RELAYER_PORT=8787
RELAYER_ALLOWED_ORIGIN=http://localhost:5173

# NEAR Intents 1Click partner authentication. Configure the credential issued
# by your Partner Dashboard; the relayer supports either header format.
NEAR_1CLICK_API_KEY=
NEAR_1CLICK_JWT=
NEAR_1CLICK_BASE_URL=https://1click.chaindefuser.com

# Destination treasury. The default asset is native NEAR USDC (6 decimals).
SETTLEMENT_ASSET_ID=nep141:17208628f84f5d6ad33f0da3bbbeb27ffcb398eac501a31bd6ad2011e36133a1
SETTLEMENT_RECIPIENT=your-treasury.near
SETTLEMENT_RECIPIENT_TYPE=DESTINATION_CHAIN
SETTLEMENT_SLIPPAGE_BPS=100

# Preferred production connection: export the relayer identity to a protected
# PEM file and call launcher_backend through the JS agent (no icp binary needed).
ICP_ENVIRONMENT=local
ICP_API_HOST=http://127.0.0.1:8000
ICP_BACKEND_CANISTER=launcher_backend
ICP_RELAYER_PEM_PATH=

# Local-development fallback: call launcher_backend through icp-cli.
ICP_RELAYER_IDENTITY=
ICP_CLI=icp

# Frontend production builds must point at the HTTPS relayer URL.
VITE_RELAYER_URL=
